{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "demucs-web",
  "main": "./cloudflare/worker.mjs",
  "compatibility_date": "2026-03-12",
  "assets": {
    "binding": "ASSETS",
    "directory": "./deploy-cloudflare-pages",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page",
    "run_worker_first": [
      "/model/*"
    ]
  }
}
